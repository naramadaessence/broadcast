# Server
PORT=3000
NODE_ENV=development

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=crm_saas

# JWT
JWT_SECRET=dev-only-secret-not-for-production
JWT_EXPIRATION=86400

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173

# App Domain (for subdomain tenant routing)
APP_DOMAIN=localhost

# Super Admin Emails (comma-separated, platform owners)
SUPER_ADMIN_EMAILS=admin@localhost

# SMTP / Email
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=noreply@localhost
SMTP_TO_EMAIL=admin@localhost

# Razorpay (subscription billing)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

AI_API_KEY=
